{
  "name": "zord-console",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone-assets.mjs",
    "start": "node .next/standalone/server.js",
    "start:next": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "verify:api-routes": "node scripts/verify-payout-api-routes.mjs && node scripts/verify-console-page-routes.mjs && node scripts/verify-tenant-batch-scope.mjs && node scripts/verify-journal-api-metrics.mjs && node scripts/verify-payout-mock-allowlist.mjs",
    "verify:tenant-scope": "node scripts/verify-tenant-batch-scope.mjs",
    "clean": "rm -rf .next node_modules/.cache",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f zord-console",
    "docker:recreate": "docker compose up --build --force-recreate -d",
    "docker:reset": "docker compose down --remove-orphans && npm run clean && docker compose up --build -d",
    "deploy": "npm run docker:build && npm run docker:up",
    "health": "curl -f http://localhost:3000/api/health"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^1.17.0",
    "next": "^14.2.29",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^8.0.7",
    "recharts": "^2.12.7",
    "remark-gfm": "^3.0.1",
    "sharp": "^0.33.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "minimatch": "^9.0.5",
    "picomatch": "^4.0.2",
    "glob": "^10.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "20.19.33",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.29",
    "playwright": "^1.58.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "5.9.3"
  }
}
