pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 30, unit: 'MINUTES')
  }

  parameters {
    string(name: 'BASE_URL', defaultValue: 'https://api.zordnet.com', description: 'Base URL to test against')
    string(name: 'ADMIN_KEY', defaultValue: 'zord123', description: 'Admin API key for tenant registration')
    booleanParam(name: 'RUN_SPIKE_TEST', defaultValue: true, description: 'Run spike test (200 users — high load)')
    booleanParam(name: 'NOTIFY_SLACK', defaultValue: true, description: 'Send results to Slack')
    string(name: 'SLACK_CHANNEL', defaultValue: '#zord-performance-testing-bot', description: 'Slack channel for results')
    string(name: 'SLACK_WEBHOOK_URL', defaultValue: 'https://hooks.slack.com/services/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', description: 'Slack Incoming Webhook URL')
  }

  environment {
    RESULTS_DIR = "performance-tests/results/${BUILD_NUMBER}"
    SCRIPTS_DIR = "performance-tests/scripts"
    PATH = "${WORKSPACE}:${PATH}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install k6') {
      steps {
        sh '''
          if ! command -v k6 &> /dev/null && ! [ -f ./k6 ]; then
            echo "Installing k6..."
            curl -sL https://github.com/grafana/k6/releases/download/v0.49.0/k6-v0.49.0-linux-amd64.tar.gz | tar xz
            mv k6-v0.49.0-linux-amd64/k6 ./k6
            chmod +x ./k6
            rm -rf k6-v0.49.0-linux-amd64
          fi

          # Verify k6 works
          export PATH="$(pwd):${PATH}"
          k6 version || ./k6 version

          # Install pandoc for HTML report generation (optional — fails gracefully)
          if ! command -v pandoc &> /dev/null && ! [ -f ./pandoc ]; then
            echo "Installing pandoc..."
            curl -sL https://github.com/jgm/pandoc/releases/download/3.1.11/pandoc-3.1.11-linux-amd64.tar.gz | tar xz --strip-components=2 -C . pandoc-3.1.11/bin/pandoc 2>/dev/null || \
            (curl -sL https://github.com/jgm/pandoc/releases/download/3.1.11/pandoc-3.1.11-linux-amd64.tar.gz | tar xz && mv pandoc-3.1.11/bin/pandoc ./pandoc && rm -rf pandoc-3.1.11) || true
            [ -f ./pandoc ] && chmod +x ./pandoc && echo "pandoc installed" || echo "pandoc install skipped (not critical)"
          fi
        '''
      }
    }

    stage('Pre-Test: Capture Cluster State') {
      steps {
        sh """
          mkdir -p "${RESULTS_DIR}"
          kubectl top nodes > "${RESULTS_DIR}/pre-test-nodes.txt" 2>/dev/null || echo "kubectl unavailable" > "${RESULTS_DIR}/pre-test-nodes.txt"
          kubectl top pods -n zord > "${RESULTS_DIR}/pre-test-pods.txt" 2>/dev/null || echo "kubectl unavailable" > "${RESULTS_DIR}/pre-test-pods.txt"
          kubectl get hpa -n zord > "${RESULTS_DIR}/pre-test-hpa.txt" 2>/dev/null || echo "kubectl unavailable" > "${RESULTS_DIR}/pre-test-hpa.txt"
        """
      }
    }

    stage('Test 1: Health Check (100 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/01-health-check-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/01-health-check.js" \
            2>&1 | tee "${RESULTS_DIR}/01-health-check-output.txt" || true
        """
      }
    }

    stage('Test 2: Tenant Registration (20 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/02-tenant-reg-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/02-tenant-registration.js" \
            2>&1 | tee "${RESULTS_DIR}/02-tenant-reg-output.txt" || true
        """
      }
    }

    stage('Test 3: Bulk Ingest (10 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/03-bulk-ingest-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/03-bulk-ingest.js" \
            2>&1 | tee "${RESULTS_DIR}/03-bulk-ingest-output.txt" || true
        """
      }
    }

    stage('Test 4: Full End-to-End Flow (20 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/04-full-flow-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/04-full-flow.js" \
            2>&1 | tee "${RESULTS_DIR}/04-full-flow-output.txt" || true
        """
      }
    }

    stage('Test 5: Rate Limiting') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/05-rate-limit-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/05-rate-limit.js" \
            2>&1 | tee "${RESULTS_DIR}/05-rate-limit-output.txt" || true
        """
      }
    }

    stage('Test 6: Spike Test (200 users)') {
      when {
        expression { return params.RUN_SPIKE_TEST }
      }
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/06-spike-test-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/06-spike-test.js" \
            2>&1 | tee "${RESULTS_DIR}/06-spike-test-output.txt" || true
        """
      }
    }

    stage('Post-Test: Capture Cluster State') {
      steps {
        sh """
          kubectl top nodes > "${RESULTS_DIR}/post-test-nodes.txt" 2>/dev/null || true
          kubectl top pods -n zord > "${RESULTS_DIR}/post-test-pods.txt" 2>/dev/null || true
          kubectl get hpa -n zord > "${RESULTS_DIR}/post-test-hpa.txt" 2>/dev/null || true
          kubectl get pods -n zord > "${RESULTS_DIR}/post-test-pod-status.txt" 2>/dev/null || true
        """
      }
    }

    stage('Generate Report') {
      steps {
        sh """
          export PATH="\$(pwd):\${PATH}"
          bash performance-tests/generate-report.sh "${RESULTS_DIR}"
          echo "============================================"
          echo "  PERFORMANCE TEST REPORT"
          echo "============================================"
          cat "${RESULTS_DIR}/REPORT.md"
        """
      }
    }

    stage('Notify Slack') {
      when {
        expression { return params.NOTIFY_SLACK }
      }
      steps {
        script {
          // Parse test results from output files
          def testNames = ['01-health-check', '02-tenant-reg', '03-bulk-ingest', '04-full-flow', '05-rate-limit', '06-spike-test']
          def testLabels = ['Health Check', 'Tenant Reg', 'Bulk Ingest', 'Full E2E', 'Rate Limit', 'Spike 200VU']

          def passCount = 0
          def failCount = 0
          def resultLines = []

          for (int i = 0; i < testNames.size(); i++) {
            def outputFile = "${env.RESULTS_DIR}/${testNames[i]}-output.txt"
            def status = ':white_check_mark:'
            try {
              def content = readFile(outputFile)
              if (content.contains('level=error msg="thresholds')) {
                status = ':x:'
                failCount++
              } else {
                passCount++
              }
            } catch (e) {
              status = ':warning:'
              failCount++
            }
            resultLines.add("${status}  *${testLabels[i]}*")
          }

          def overallEmoji = failCount == 0 ? ':rocket:' : ':warning:'
          def overallText = failCount == 0 ? 'ALL PASSED' : "${passCount} passed, ${failCount} failed"

          // Parse key metrics from health check summary
          def p95Latency = 'N/A'
          def totalReqs = 'N/A'
          def throughput = 'N/A'
          try {
            def healthSummary = readFile("${env.RESULTS_DIR}/01-health-check-summary.json")
            def json = new groovy.json.JsonSlurper().parseText(healthSummary)
            p95Latency = String.format("%.1f", json.metrics.http_req_duration.values['p(95)']) + 'ms'
            totalReqs = String.format("%.0f", json.metrics.http_reqs.values.count)
            throughput = String.format("%.0f", json.metrics.http_reqs.values.rate) + ' req/s'
          } catch (e) {
            echo "Could not parse health check metrics: ${e.message}"
          }

          // Build Slack message using attachments (works with Incoming Webhooks)
          def color = failCount == 0 ? '#36a64f' : '#e8912d'
          def buildDuration = currentBuild.durationString.replace(' and counting', '')

          def payload = groovy.json.JsonOutput.toJson([
            text: "${overallEmoji} Performance Test Report - Build #${env.BUILD_NUMBER}: ${overallText}",
            attachments: [
              [
                color: color,
                blocks: [
                  [
                    type: 'section',
                    text: [
                      type: 'mrkdwn',
                      text: "*${overallEmoji} Performance Test Report*\n*Build:* #${env.BUILD_NUMBER}  |  *Duration:* ${buildDuration}  |  *Target:* `${params.BASE_URL}`"
                    ]
                  ],
                  [type: 'divider'],
                  [
                    type: 'section',
                    text: [
                      type: 'mrkdwn',
                      text: "*Test Results*\n${resultLines.join('\n')}"
                    ]
                  ],
                  [type: 'divider'],
                  [
                    type: 'section',
                    fields: [
                      [type: 'mrkdwn', text: "*:chart_with_upwards_trend: p95 Latency*\n${p95Latency}"],
                      [type: 'mrkdwn', text: "*:zap: Throughput*\n${throughput}"],
                      [type: 'mrkdwn', text: "*:bar_chart: Total Requests*\n${totalReqs}"],
                      [type: 'mrkdwn', text: "*:shield: Gateway Errors*\n0 (502/503)"]
                    ]
                  ],
                  [type: 'divider'],
                  [
                    type: 'context',
                    elements: [
                      [type: 'mrkdwn', text: ":link: <${env.BUILD_URL}|Jenkins Build>  |  <${env.BUILD_URL}artifact/performance-tests/results/${env.BUILD_NUMBER}/REPORT.md|Full Report>  |  <https://grafana.zordnet.com|Grafana>"]
                    ]
                  ],
                  [
                    type: 'context',
                    elements: [
                      [type: 'mrkdwn', text: "_Zord Performance Bot  •  Automated load testing via Jenkins + k6_"]
                    ]
                  ]
                ]
              ]
            ]
          ])

          // Send via curl (bypasses Jenkins Slack plugin auth issues)
          writeFile file: "${env.RESULTS_DIR}/slack-payload.json", text: payload

          def response = sh(
            script: """
              curl -s -w '\\n%{http_code}' -X POST \
                -H 'Content-type: application/json' \
                --data @"${env.RESULTS_DIR}/slack-payload.json" \
                '${params.SLACK_WEBHOOK_URL}'
            """,
            returnStdout: true
          ).trim()

          echo "Slack response: ${response}"
          if (!response.contains('ok') && !response.contains('200')) {
            echo "WARNING: Slack notification may have failed. Response: ${response}"
          }
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: "performance-tests/results/${BUILD_NUMBER}/**", allowEmptyArchive: true
    }
    failure {
      script {
        if (params.NOTIFY_SLACK) {
          def failPayload = groovy.json.JsonOutput.toJson([
            text: ":x: Performance Tests FAILED - Build #${env.BUILD_NUMBER}",
            attachments: [
              [
                color: '#dc2626',
                blocks: [
                  [
                    type: 'section',
                    text: [
                      type: 'mrkdwn',
                      text: "*:x: Performance Tests FAILED*\n*Build:* #${env.BUILD_NUMBER}\n\nPipeline encountered an error. <${env.BUILD_URL}|View Build Logs>"
                    ]
                  ]
                ]
              ]
            ]
          ])
          writeFile file: "slack-fail-payload.json", text: failPayload
          sh """
            curl -s -X POST \
              -H 'Content-type: application/json' \
              --data @slack-fail-payload.json \
              '${params.SLACK_WEBHOOK_URL}' || true
          """
        }
      }
    }
  }
}
