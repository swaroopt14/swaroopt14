pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 45, unit: 'MINUTES')
  }

  parameters {
    string(name: 'BASE_URL', defaultValue: 'https://api.zordnet.com', description: 'Base URL to test against')
    string(name: 'ADMIN_KEY', defaultValue: 'zord123', description: 'Admin API key for tenant registration')
    booleanParam(name: 'RUN_SPIKE_TEST', defaultValue: true, description: 'Run spike test (200 users)')
    booleanParam(name: 'RUN_AI_TEST', defaultValue: true, description: 'Run AI copilot test (LLM — slow)')
    booleanParam(name: 'NOTIFY_SLACK', defaultValue: true, description: 'Send results to Slack')
  }

  environment {
    RESULTS_DIR = "performance-tests/results/${BUILD_NUMBER}"
    SCRIPTS_DIR = "performance-tests/scripts"
    PATH = "${WORKSPACE}:${PATH}"
    SLACK_WEBHOOK_URL = credentials('slack-webhook')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Tools') {
      steps {
        sh '''
          if ! command -v k6 &> /dev/null && ! [ -f ./k6 ]; then
            echo "Installing k6..."
            curl -sL https://github.com/grafana/k6/releases/download/v0.49.0/k6-v0.49.0-linux-amd64.tar.gz | tar xz
            mv k6-v0.49.0-linux-amd64/k6 ./k6 && chmod +x ./k6
            rm -rf k6-v0.49.0-linux-amd64
          fi
          export PATH="$(pwd):${PATH}"
          k6 version || ./k6 version
        '''
      }
    }

    stage('Pre-Test: Cluster State') {
      steps {
        sh """
          mkdir -p "${RESULTS_DIR}"
          echo "=== Node Resources ===" > "${RESULTS_DIR}/pre-test-nodes.txt"
          kubectl top nodes >> "${RESULTS_DIR}/pre-test-nodes.txt" 2>/dev/null || echo "kubectl unavailable" >> "${RESULTS_DIR}/pre-test-nodes.txt"
          kubectl get pods -n zord -o wide > "${RESULTS_DIR}/pre-test-pods.txt" 2>/dev/null || true
          kubectl get pods -n api-gateway -o wide >> "${RESULTS_DIR}/pre-test-pods.txt" 2>/dev/null || true
          kubectl get hpa -n zord > "${RESULTS_DIR}/pre-test-hpa.txt" 2>/dev/null || true
          kubectl get hpa -n api-gateway >> "${RESULTS_DIR}/pre-test-hpa.txt" 2>/dev/null || true
        """
      }
    }

    stage('Test 1: Health Check (100 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/01-health-check-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/01-health-check.js" \
            2>&1 | tee "${RESULTS_DIR}/01-health-check-output.txt" || true
        """
      }
    }

    stage('Test 2: Tenant Registration (20 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/02-tenant-reg-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/02-tenant-registration.js" \
            2>&1 | tee "${RESULTS_DIR}/02-tenant-reg-output.txt" || true
        """
      }
    }

    stage('Test 3: Ingest Pipeline (10 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/03-bulk-ingest-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/03-bulk-ingest.js" \
            2>&1 | tee "${RESULTS_DIR}/03-bulk-ingest-output.txt" || true
        """
      }
    }

    stage('Test 4: Full E2E Flow (20 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/04-full-flow-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/04-full-flow.js" \
            2>&1 | tee "${RESULTS_DIR}/04-full-flow-output.txt" || true
        """
      }
    }

    stage('Test 5: Rate Limiting') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/05-rate-limit-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/05-rate-limit.js" \
            2>&1 | tee "${RESULTS_DIR}/05-rate-limit-output.txt" || true
        """
      }
    }

    stage('Test 6: Spike Test (200 VUs)') {
      when { expression { return params.RUN_SPIKE_TEST } }
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/06-spike-test-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/06-spike-test.js" \
            2>&1 | tee "${RESULTS_DIR}/06-spike-test-output.txt" || true
        """
      }
    }

    stage('Test 7: Intelligence Surface (15 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/07-intelligence-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/07-intelligence-surface.js" \
            2>&1 | tee "${RESULTS_DIR}/07-intelligence-output.txt" || true
        """
      }
    }

    stage('Test 8: AI Copilot (10 VUs)') {
      when { expression { return params.RUN_AI_TEST } }
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/08-ai-copilot-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/08-ai-copilot.js" \
            2>&1 | tee "${RESULTS_DIR}/08-ai-copilot-output.txt" || true
        """
      }
    }

    stage('Test 9: Security & CORS (20 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/09-security-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/09-security-headers.js" \
            2>&1 | tee "${RESULTS_DIR}/09-security-output.txt" || true
        """
      }
    }

    stage('Post-Test: Cluster State') {
      steps {
        sh """
          echo "=== Node Resources ===" > "${RESULTS_DIR}/post-test-nodes.txt"
          kubectl top nodes >> "${RESULTS_DIR}/post-test-nodes.txt" 2>/dev/null || echo "kubectl unavailable" >> "${RESULTS_DIR}/post-test-nodes.txt"

          echo "=== Pod Resources (zord namespace) ===" > "${RESULTS_DIR}/post-test-pods.txt"
          kubectl top pods -n zord >> "${RESULTS_DIR}/post-test-pods.txt" 2>/dev/null || true
          echo "" >> "${RESULTS_DIR}/post-test-pods.txt"
          echo "=== Pod Resources (api-gateway namespace) ===" >> "${RESULTS_DIR}/post-test-pods.txt"
          kubectl top pods -n api-gateway >> "${RESULTS_DIR}/post-test-pods.txt" 2>/dev/null || true

          echo "=== HPA Status (zord) ===" > "${RESULTS_DIR}/post-test-hpa.txt"
          kubectl get hpa -n zord >> "${RESULTS_DIR}/post-test-hpa.txt" 2>/dev/null || true
          echo "" >> "${RESULTS_DIR}/post-test-hpa.txt"
          echo "=== HPA Status (api-gateway) ===" >> "${RESULTS_DIR}/post-test-hpa.txt"
          kubectl get hpa -n api-gateway >> "${RESULTS_DIR}/post-test-hpa.txt" 2>/dev/null || true

          echo "=== Pod Status ===" > "${RESULTS_DIR}/post-test-pod-status.txt"
          kubectl get pods -n zord -o wide >> "${RESULTS_DIR}/post-test-pod-status.txt" 2>/dev/null || true
          echo "" >> "${RESULTS_DIR}/post-test-pod-status.txt"
          kubectl get pods -n api-gateway -o wide >> "${RESULTS_DIR}/post-test-pod-status.txt" 2>/dev/null || true
        """
      }
    }

    stage('Generate Report') {
      steps {
        sh """
          export PATH="\$(pwd):\${PATH}"
          bash performance-tests/generate-report.sh "${RESULTS_DIR}"
          echo "============================================"
          echo "  PERFORMANCE TEST REPORT"
          echo "============================================"
          cat "${RESULTS_DIR}/REPORT.md"
        """
      }
    }

    stage('Notify Slack') {
      when { expression { return params.NOTIFY_SLACK } }
      steps {
        script {
          def testNames = ['01-health-check', '02-tenant-reg', '03-bulk-ingest', '04-full-flow', '05-rate-limit', '06-spike-test', '07-intelligence', '08-ai-copilot', '09-security']
          def testLabels = ['Health Check (9 services)', 'Tenant Registration', 'Ingest Pipeline (JSON+CSV)', 'Full E2E (12 services)', 'Rate Limiting (3 routes)', 'Spike Test (200 VUs)', 'Intelligence APIs', 'AI Copilot (LLM)', 'Security & CORS']
          def testTargets = ['p95 < 500ms', 'p95 < 2s', 'p95 < 5s', 'p95 < 5s', '429 triggers', '< 5% errors', 'p95 < 3s', 'p95 < 10s', 'Headers present']

          def passCount = 0
          def failCount = 0
          def detailLines = []
          def failedDetails = []
          def tableRows = []
          def notFullyPassedDetails = []

          for (int i = 0; i < testNames.size(); i++) {
            def outputFile = "${env.RESULTS_DIR}/${testNames[i]}-output.txt"
            def summaryFile = "${env.RESULTS_DIR}/${testNames[i]}-summary.json"
            def status = ':white_check_mark:'
            def metrics = ''
            def testReqs = '-'
            def testP95 = '-'
            def testChecks = '-'

            try {
              def content = readFile(outputFile)
              if (content.contains('level=error msg="thresholds')) {
                status = ':x:'
                failCount++
                def failedChecks = []
                content.eachLine { line ->
                  if (line.contains('✗') && !line.contains('↳')) {
                    failedChecks.add(line.trim().replaceAll(/\s+/, ' '))
                  }
                }
                if (failedChecks.size() > 0) {
                  failedDetails.add("*${testLabels[i]}:*\n" + failedChecks.take(3).collect { "  `${it}`" }.join('\n'))
                }
              } else {
                passCount++
              }

              // Parse metrics from output text (reliable — always works)
              def p95Match = (content =~ /p\(95\)=([0-9.]+)(ms|µs|s)/)
              def reqMatch = (content =~ /http_reqs[.\s:]+(\d+)/)
              def checksMatch = (content =~ /checks[.\s:]+([0-9.]+)%/)
              if (p95Match) {
                def val = p95Match[0][1] as Double
                def unit = p95Match[0][2]
                if (unit == 'µs') testP95 = String.format("%.0f", val / 1000) + 'ms'
                else if (unit == 's') testP95 = String.format("%.0f", val * 1000) + 'ms'
                else testP95 = String.format("%.0f", val) + 'ms'
              }
              if (reqMatch) testReqs = reqMatch[0][1]
              if (checksMatch) testChecks = checksMatch[0][1] + '%'

              // If checks < 100%, extract which checks failed and explain why
              def checksVal = checksMatch ? (checksMatch[0][1] as Double) : 100.0
              if (checksVal < 100.0) {
                def checkNames = []
                def lines = content.split('\n')
                for (int li = 0; li < lines.size(); li++) {
                  if (lines[li].contains('✗') && !lines[li].contains('↳')) {
                    def checkName = lines[li].trim().replaceAll(/✗\s*/, '').replaceAll(/\s+/, ' ').trim()
                    def detailLine = (li + 1 < lines.size() && lines[li + 1].contains('↳')) ? lines[li + 1].trim() : ''
                    // Extract pass/fail counts
                    def countMatch = (detailLine =~ /✓\s*(\d+)\s*\/\s*✗\s*(\d+)/)
                    def passN = countMatch ? countMatch[0][1] : '?'
                    def failN = countMatch ? countMatch[0][2] : '?'

                    // Translate to human-readable explanation with root cause + fix
                    def explanation = ''
                    if (checkName.contains('response time')) {
                      explanation = "${failN} requests took longer than expected.\n      _Root cause:_ Service under heavy load or DB query slow.\n      _Fix:_ Check Grafana CPU/memory. Check DB slow query logs in Kibana."
                    } else if (checkName.contains('tenant created') || checkName.contains('201')) {
                      explanation = "${failN} tenant registrations failed.\n      _Root cause:_ DB connection timeout or duplicate name conflict.\n      _Fix:_ Check zord-edge pod logs in Kibana. Verify DB_HOST and EDGE_DB_PASSWORD secrets are correct."
                    } else if (checkName.contains('ingest accepted') || checkName.contains('auth error')) {
                      explanation = "${failN} ingest requests got unexpected status code.\n      _Root cause:_ The endpoint returned something other than 200/201/401/429. Likely 400 (bad payload format) or 422 (validation).\n      _Fix:_ Check if the ingest JSON schema changed. Verify X-Idempotency-Key header is being sent."
                    } else if (checkName.contains('rate limit')) {
                      explanation = "Kong is not sending X-RateLimit headers on this route.\n      _Root cause:_ Rate limiting plugin may not be applied to health endpoints, or hide_client_headers is set to true.\n      _Fix:_ Check Kong configmap — verify rate-limiting plugin has hide_client_headers: false."
                    } else if (checkName.contains('server error') || checkName.contains('5xx') || checkName.contains('not server error')) {
                      explanation = "${failN} requests got HTTP 500.\n      _Root cause:_ Backend service crashed or DB connection lost.\n      _Fix:_ Check pod logs in Kibana for panic/stack trace. Verify DB secrets and Kafka broker connectivity."
                    } else if (checkName.contains('reachable') || checkName.contains('alive') || checkName.contains('502') || checkName.contains('503')) {
                      explanation = "${failN} requests got 502/503 Bad Gateway.\n      _Root cause:_ Backend pod crashed, restarted, or not ready.\n      _Fix:_ Run kubectl get pods -n zord. Check if pod restarted. Check readiness probe path."
                    } else if (checkName.contains('Server header')) {
                      explanation = "Kong still returns Server header in responses.\n      _Root cause:_ The response-transformer plugin is not stripping it from all routes (or ALB adds its own).\n      _Fix:_ Edit Kong configmap → response-transformer → add Server to remove.headers for specific routes."
                    } else if (checkName.contains('CORS') || checkName.contains('zordnet')) {
                      explanation = "CORS Access-Control-Allow-Origin header missing.\n      _Root cause:_ The request Origin doesn't match Kong's allowed origins, or CORS plugin not applied globally.\n      _Fix:_ Check Kong configmap → cors plugin → verify origins list includes the tested domain."
                    } else if (checkName.contains('HSTS') || checkName.contains('X-Frame') || checkName.contains('nosniff')) {
                      explanation = "Security header missing from response.\n      _Root cause:_ response-transformer plugin not adding this header.\n      _Fix:_ Check Kong configmap → response-transformer → config.add.headers list."
                    } else if (checkName.contains('body') || checkName.contains('present')) {
                      explanation = "${failN} responses had empty body.\n      _Root cause:_ Service returned empty response — possibly timeout or connection reset.\n      _Fix:_ Check service logs for context deadline exceeded errors."
                    } else {
                      explanation = "${passN} passed, ${failN} failed.\n      _Fix:_ Check the full test output in Jenkins artifacts for details."
                    }

                    checkNames.add(":small_orange_diamond: *${checkName}* — ${explanation}")
                  }
                }
                if (checkNames.size() > 0) {
                  notFullyPassedDetails.add("*${testLabels[i]}* (${testChecks}):\n" + checkNames.take(4).join('\n'))
                }
              }
            } catch (e) {
              status = ':fast_forward:'
              testChecks = 'skip'
            }

            detailLines.add("${status} *${testLabels[i]}*")
            tableRows.add([num: String.format("%02d", i + 1), name: testLabels[i], status: (status == ':white_check_mark:' ? '✅' : (status == ':x:' ? '❌' : '⏭')), reqs: testReqs, p95: testP95, checks: testChecks])
          }

          def overallStatus = failCount == 0 ? ':white_check_mark: ALL 9 TESTS PASSED' : ":warning: ${failCount} FAILED — ${passCount} passed"

          // Parse E2E service status from Test 04
          def serviceStatus = ''
          try {
            def e2eContent = readFile("${env.RESULTS_DIR}/04-full-flow-output.txt")
            def serviceChecks = ['tenant endpoint reachable', 'ingest reachable', 'intents reachable', 'dlq reachable', 'dispatch reachable', 'settlement psps reachable', 'settlement upload reachable', 'evidence reachable', 'projections reachable', 'policies reachable', 'ai query reachable', 'ai chat reachable']
            def upCount = 0
            def downServices = []
            def checkLabels = ['zord-edge', 'zord-edge (ingest)', 'zord-intent-engine', 'zord-intent-engine (DLQ)', 'zord-relay', 'zord-outcome-engine', 'zord-outcome-engine (upload)', 'zord-evidence', 'zord-intelligence', 'zord-intelligence (policies)', 'zord-prompt-layer', 'zord-prompt-layer (chat)']

            for (int j = 0; j < serviceChecks.size(); j++) {
              if (e2eContent.contains(serviceChecks[j])) {
                upCount++
              } else {
                downServices.add(checkLabels[j])
              }
            }

            if (downServices.size() > 0) {
              serviceStatus = "\n:red_circle: *Services DOWN:* ${downServices.join(', ')}"
            } else if (upCount > 0) {
              def svcTable = "```#   Service                        Status\n"
              svcTable += "──  ─────────────────────────────  ──────\n"
              for (int j = 0; j < checkLabels.size(); j++) {
                def svcStatus = downServices.contains(checkLabels[j]) ? '❌ DOWN' : '✅ UP'
                svcTable += String.format("%-3s %-33s %s\n", (j+1).toString(), checkLabels[j], svcStatus)
              }
              svcTable += "```"
              serviceStatus = "\n" + svcTable
            }
          } catch (e) { }

          def duration = currentBuild.durationString.replace(' and counting', '')
          def color = failCount == 0 ? '#2eb886' : (failCount <= 2 ? '#e8912d' : '#dc2626')
          def timestamp = new Date().format("MMM d, yyyy 'at' h:mm a z")

          // Build table string (monospace — looks like a real table in Slack)
          def tableHeader = '#   Test                      Status  Requests   p95      Checks'
          def tableDivider = '──  ────────────────────────  ──────  ─────────  ───────  ──────'
          def tableBody = tableRows.collect { row ->
            String.format("%-3s %-26s %-6s %9s  %7s  %s", row.num, row.name.take(26), row.status, row.reqs, row.p95, row.checks)
          }.join('\n')

          // Calculate totals from table data
          def totalReqs = 0L
          def maxP95 = 0.0
          tableRows.each { row ->
            if (row.reqs != '-') totalReqs += (row.reqs as Long)
            if (row.p95 != '-') {
              def val = row.p95.replace('ms','') as Double
              if (val > maxP95) maxP95 = val
            }
          }
          def overallP95 = maxP95 > 0 ? String.format("%.0f", maxP95) + 'ms' : 'N/A'
          def summaryLine = "──  ────────────────────────  ──────  ─────────  ───────  ──────\n    TOTAL                             ${String.format('%9s', totalReqs)}  ${String.format('%7s', overallP95)}  ${passCount}/${passCount + failCount} pass"

          def fullTable = "```${tableHeader}\n${tableDivider}\n${tableBody}\n${summaryLine}```"

          // Build blocks — minimize block count to avoid Slack "Show more" truncation
          def blocks = [
            [type: 'header', text: [type: 'plain_text', text: "Zord Performance Report — Build #${env.BUILD_NUMBER}", emoji: true]],
            [type: 'context', elements: [
              [type: 'mrkdwn', text: ":calendar: ${timestamp}  |  :stopwatch: ${duration}  |  :globe_with_meridians: `${params.BASE_URL}`"]
            ]],
            [type: 'section', text: [type: 'mrkdwn', text: "*${overallStatus}*"]],
            [type: 'section', text: [type: 'mrkdwn', text: "${serviceStatus}"]],
            [type: 'section', text: [type: 'mrkdwn', text: fullTable]],
          ]

          // Message 1: Main results (services + test table + links)
          blocks.add([type: 'section', text: [type: 'mrkdwn', text: "*:link: Quick Links*\n<${env.BUILD_URL}artifact/${env.RESULTS_DIR}/REPORT.md|:page_facing_up: Report>  |  <${env.BUILD_URL}console|:mag: Console>  |  <https://grafana.zordnet.com/d/zord-platform-health?orgId=1&from=now-1h&to=now|:chart_with_downwards_trend: Grafana>  |  <https://kibana.zordnet.com|:ledger: Kibana>  |  <https://jaeger.zordnet.com|:mag_right: Jaeger>"]])

          def payload = groovy.json.JsonOutput.toJson([
            text: ":test_tube: Zord Performance Report #${env.BUILD_NUMBER} — ${overallStatus}",
            attachments: [[color: color, blocks: blocks]]
          ])

          writeFile file: "${env.RESULTS_DIR}/slack-payload.json", text: payload
          def resp = sh(script: """curl -s -w '\\n%{http_code}' -X POST -H 'Content-type: application/json' --data @"${env.RESULTS_DIR}/slack-payload.json" '${env.SLACK_WEBHOOK_URL}'""", returnStdout: true).trim()
          echo "Slack Message 1: ${resp}"

          // Message 2: "Why not 100%?" details (separate message so it's always visible)
          def hasDetails = (notFullyPassedDetails.size() > 0 || failedDetails.size() > 0)
          echo "notFullyPassedDetails size: ${notFullyPassedDetails.size()}, failedDetails size: ${failedDetails.size()}"
          if (notFullyPassedDetails.size() > 0) {
            echo "Why not 100% content: ${notFullyPassedDetails}"
          }

          // Always send second message if ANY test is not exactly 100%
          def testsBelow100 = tableRows.findAll { it.checks != '-' && it.checks != '100%' && it.checks != '100.00%' }
          echo "Tests below 100%: ${testsBelow100.collect { it.name + '=' + it.checks }}"

          if (hasDetails || testsBelow100.size() > 0) {
            sleep 2  // Wait 2 seconds so Slack doesn't deduplicate

            def blocks2 = []

            if (failedDetails.size() > 0) {
              blocks2.add([type: 'section', text: [type: 'mrkdwn', text: "*:rotating_light: Threshold Failures (Build #${env.BUILD_NUMBER}):*\n${failedDetails.join('\n\n')}\n\n:point_right: *Action:* Check Grafana + Kibana"]])
            }

            if (notFullyPassedDetails.size() > 0) {
              blocks2.add([type: 'section', text: [type: 'mrkdwn', text: "*:mag: Why not 100%? (Build #${env.BUILD_NUMBER})*\n${notFullyPassedDetails.take(4).join('\n\n')}"]])
            } else if (testsBelow100.size() > 0) {
              // Fallback: show which tests are below 100% with detailed reasons
              def fallbackLines = testsBelow100.collect { row ->
                def reason = ''
                if (row.name.contains('Health')) reason = "Few requests took >500ms under 100 concurrent users. This is normal network jitter — not a platform issue.\n_Root cause:_ Momentary CPU spike or GC pause on one pod.\n_Fix:_ No action needed unless p95 exceeds 500ms consistently."
                else if (row.name.contains('Tenant')) reason = "Some tenant registrations returned unexpected status. Likely duplicate name collision — test creates tenants with timestamps, and at 20 concurrent users, two can hit the same millisecond.\n_Root cause:_ DB unique constraint violation (expected under load).\n_Fix:_ No action needed. If persistent, check DB connection pool exhaustion in Grafana."
                else if (row.name.contains('E2E') || row.name.contains('Full')) reason = "1-2 requests across 12 services returned unexpected status. At 20 concurrent users doing 12 API calls each, occasional timeout or rate-limit hit is expected.\n_Root cause:_ Kong rate limiting or momentary pod restart.\n_Fix:_ Check if any pod restarted during test window (kubectl get pods)."
                else if (row.name.contains('Ingest')) reason = "Some ingest requests returned 400 (bad request). The test payload may not exactly match what the middleware validates.\n_Root cause:_ Payload validation mismatch or missing required field.\n_Fix:_ Check zord-edge pod logs for validation error details."
                else if (row.name.contains('Security')) reason = "Kong does not include X-RateLimit-* headers on 429 responses. When the rate limit is exceeded, the 429 response has no rate headers — only successful pass-through gets them.\n_Root cause:_ This is how Kong rate-limiting plugin works by design.\n_Fix:_ Not a bug. No action needed."
                else if (row.name.contains('AI') || row.name.contains('Copilot')) reason = "AI endpoint returned non-200 for some requests. The prompt-layer requires X-Session-ID (UUID v4) and authenticated tenant context.\n_Root cause:_ Missing session header or tenant context not set.\n_Fix:_ Check prompt-layer pod logs for auth/session errors."
                else reason = "Some checks failed. Check the full console log for details."
                return ":small_orange_diamond: *${row.name}* — ${row.checks}\n${reason}"
              }.join('\n\n')
              blocks2.add([type: 'section', text: [type: 'mrkdwn', text: "*:mag: Why not 100%? (Build #${env.BUILD_NUMBER})*\n\n${fallbackLines}"]])
            }

            blocks2.add([type: 'context', elements: [
              [type: 'mrkdwn', text: "_Details from performance test run — check console log for full k6 output_"]
            ]])

            def payload2 = groovy.json.JsonOutput.toJson([
              text: ":mag: Why not 100%? — Build #${env.BUILD_NUMBER}",
              attachments: [[color: '#f0ad4e', blocks: blocks2]]
            ])

            writeFile file: "${env.RESULTS_DIR}/slack-payload2.json", text: payload2
            def resp2 = sh(script: """curl -s -w '\\n%{http_code}' -X POST -H 'Content-type: application/json' --data @"${env.RESULTS_DIR}/slack-payload2.json" '${env.SLACK_WEBHOOK_URL}'""", returnStdout: true).trim()
            echo "Slack Message 2: ${resp2}"
          } else {
            echo "All tests at 100% — no second message needed"
          }
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: "performance-tests/results/${BUILD_NUMBER}/**", allowEmptyArchive: true
    }
    failure {
      script {
        if (params.NOTIFY_SLACK) {
          def fp = groovy.json.JsonOutput.toJson([
            text: ":x: Performance Pipeline FAILED — Build #${env.BUILD_NUMBER}",
            attachments: [[color: '#dc2626', blocks: [
              [type: 'section', text: [type: 'mrkdwn', text: "*:x: Pipeline Error*\nBuild <${env.BUILD_URL}|#${env.BUILD_NUMBER}> failed. Check logs."]]
            ]]]
          ])
          writeFile file: "slack-fail.json", text: fp
          sh "curl -s -X POST -H 'Content-type: application/json' --data @slack-fail.json '${env.SLACK_WEBHOOK_URL}' || true"
        }
      }
    }
  }
}
