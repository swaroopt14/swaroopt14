pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 45, unit: 'MINUTES')
  }

  parameters {
    string(name: 'BASE_URL', defaultValue: 'https://api.zordnet.com', description: 'Base URL to test against')
    string(name: 'ADMIN_KEY', defaultValue: 'zord123', description: 'Admin API key for tenant registration')
    booleanParam(name: 'RUN_SPIKE_TEST', defaultValue: true, description: 'Run spike test (200 users)')
    booleanParam(name: 'RUN_AI_TEST', defaultValue: true, description: 'Run AI copilot test (LLM — slow)')
    booleanParam(name: 'NOTIFY_SLACK', defaultValue: true, description: 'Send results to Slack')
  }

  environment {
    RESULTS_DIR = "performance-tests/results/${BUILD_NUMBER}"
    SCRIPTS_DIR = "performance-tests/scripts"
    PATH = "${WORKSPACE}:${PATH}"
    SLACK_WEBHOOK_URL = credentials('slack-webhook')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Tools') {
      steps {
        sh '''
          if ! command -v k6 &> /dev/null && ! [ -f ./k6 ]; then
            echo "Installing k6..."
            curl -sL https://github.com/grafana/k6/releases/download/v0.49.0/k6-v0.49.0-linux-amd64.tar.gz | tar xz
            mv k6-v0.49.0-linux-amd64/k6 ./k6 && chmod +x ./k6
            rm -rf k6-v0.49.0-linux-amd64
          fi
          export PATH="$(pwd):${PATH}"
          k6 version || ./k6 version
        '''
      }
    }

    stage('Pre-Test: Cluster State') {
      steps {
        sh """
          mkdir -p "${RESULTS_DIR}"
          echo "=== Node Resources ===" > "${RESULTS_DIR}/pre-test-nodes.txt"
          kubectl top nodes >> "${RESULTS_DIR}/pre-test-nodes.txt" 2>/dev/null || echo "kubectl unavailable" >> "${RESULTS_DIR}/pre-test-nodes.txt"
          kubectl get pods -n zord -o wide > "${RESULTS_DIR}/pre-test-pods.txt" 2>/dev/null || true
          kubectl get pods -n api-gateway -o wide >> "${RESULTS_DIR}/pre-test-pods.txt" 2>/dev/null || true
          kubectl get hpa -n zord > "${RESULTS_DIR}/pre-test-hpa.txt" 2>/dev/null || true
          kubectl get hpa -n api-gateway >> "${RESULTS_DIR}/pre-test-hpa.txt" 2>/dev/null || true
        """
      }
    }

    stage('Test 1: Health Check (100 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/01-health-check-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/01-health-check.js" \
            2>&1 | tee "${RESULTS_DIR}/01-health-check-output.txt" || true
        """
      }
    }

    stage('Test 2: Tenant Registration (20 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/02-tenant-reg-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/02-tenant-registration.js" \
            2>&1 | tee "${RESULTS_DIR}/02-tenant-reg-output.txt" || true
        """
      }
    }

    stage('Test 3: Ingest Pipeline (10 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/03-bulk-ingest-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/03-bulk-ingest.js" \
            2>&1 | tee "${RESULTS_DIR}/03-bulk-ingest-output.txt" || true
        """
      }
    }

    stage('Test 4: Full E2E Flow (20 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/04-full-flow-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/04-full-flow.js" \
            2>&1 | tee "${RESULTS_DIR}/04-full-flow-output.txt" || true
        """
      }
    }

    stage('Test 5: Rate Limiting') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/05-rate-limit-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/05-rate-limit.js" \
            2>&1 | tee "${RESULTS_DIR}/05-rate-limit-output.txt" || true
        """
      }
    }

    stage('Test 6: Spike Test (200 VUs)') {
      when { expression { return params.RUN_SPIKE_TEST } }
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/06-spike-test-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/06-spike-test.js" \
            2>&1 | tee "${RESULTS_DIR}/06-spike-test-output.txt" || true
        """
      }
    }

    stage('Test 7: Intelligence Surface (15 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/07-intelligence-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/07-intelligence-surface.js" \
            2>&1 | tee "${RESULTS_DIR}/07-intelligence-output.txt" || true
        """
      }
    }

    stage('Test 8: AI Copilot (10 VUs)') {
      when { expression { return params.RUN_AI_TEST } }
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/08-ai-copilot-summary.json" \
            --env BASE_URL="${params.BASE_URL}" --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/08-ai-copilot.js" \
            2>&1 | tee "${RESULTS_DIR}/08-ai-copilot-output.txt" || true
        """
      }
    }

    stage('Test 9: Security & CORS (20 VUs)') {
      steps {
        sh """
          k6 run --summary-export="${RESULTS_DIR}/09-security-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/09-security-headers.js" \
            2>&1 | tee "${RESULTS_DIR}/09-security-output.txt" || true
        """
      }
    }

    stage('Post-Test: Cluster State') {
      steps {
        sh """
          echo "=== Node Resources ===" > "${RESULTS_DIR}/post-test-nodes.txt"
          kubectl top nodes >> "${RESULTS_DIR}/post-test-nodes.txt" 2>/dev/null || echo "kubectl unavailable" >> "${RESULTS_DIR}/post-test-nodes.txt"

          echo "=== Pod Resources (zord namespace) ===" > "${RESULTS_DIR}/post-test-pods.txt"
          kubectl top pods -n zord >> "${RESULTS_DIR}/post-test-pods.txt" 2>/dev/null || true
          echo "" >> "${RESULTS_DIR}/post-test-pods.txt"
          echo "=== Pod Resources (api-gateway namespace) ===" >> "${RESULTS_DIR}/post-test-pods.txt"
          kubectl top pods -n api-gateway >> "${RESULTS_DIR}/post-test-pods.txt" 2>/dev/null || true

          echo "=== HPA Status (zord) ===" > "${RESULTS_DIR}/post-test-hpa.txt"
          kubectl get hpa -n zord >> "${RESULTS_DIR}/post-test-hpa.txt" 2>/dev/null || true
          echo "" >> "${RESULTS_DIR}/post-test-hpa.txt"
          echo "=== HPA Status (api-gateway) ===" >> "${RESULTS_DIR}/post-test-hpa.txt"
          kubectl get hpa -n api-gateway >> "${RESULTS_DIR}/post-test-hpa.txt" 2>/dev/null || true

          echo "=== Pod Status ===" > "${RESULTS_DIR}/post-test-pod-status.txt"
          kubectl get pods -n zord -o wide >> "${RESULTS_DIR}/post-test-pod-status.txt" 2>/dev/null || true
          echo "" >> "${RESULTS_DIR}/post-test-pod-status.txt"
          kubectl get pods -n api-gateway -o wide >> "${RESULTS_DIR}/post-test-pod-status.txt" 2>/dev/null || true
        """
      }
    }

    stage('Generate Report') {
      steps {
        sh """
          export PATH="\$(pwd):\${PATH}"
          bash performance-tests/generate-report.sh "${RESULTS_DIR}"
          echo "============================================"
          echo "  PERFORMANCE TEST REPORT"
          echo "============================================"
          cat "${RESULTS_DIR}/REPORT.md"
        """
      }
    }

    stage('Notify Slack') {
      when { expression { return params.NOTIFY_SLACK } }
      steps {
        script {
          def testNames = ['01-health-check', '02-tenant-reg', '03-bulk-ingest', '04-full-flow', '05-rate-limit', '06-spike-test', '07-intelligence', '08-ai-copilot', '09-security']
          def testLabels = ['Health Check (9 services)', 'Tenant Registration', 'Ingest Pipeline (JSON+CSV)', 'Full E2E (12 services)', 'Rate Limiting (3 routes)', 'Spike Test (200 VUs)', 'Intelligence APIs', 'AI Copilot (LLM)', 'Security & CORS']
          def testTargets = ['p95 < 500ms', 'p95 < 2s', 'p95 < 5s', 'p95 < 5s', '429 triggers', '< 5% errors', 'p95 < 3s', 'p95 < 10s', 'Headers present']

          def passCount = 0
          def failCount = 0
          def detailLines = []
          def failedDetails = []

          for (int i = 0; i < testNames.size(); i++) {
            def outputFile = "${env.RESULTS_DIR}/${testNames[i]}-output.txt"
            def summaryFile = "${env.RESULTS_DIR}/${testNames[i]}-summary.json"
            def status = ':white_check_mark:'
            def metrics = ''

            try {
              def content = readFile(outputFile)
              if (content.contains('level=error msg="thresholds')) {
                status = ':x:'
                failCount++
                // Extract what failed
                def failedChecks = []
                content.eachLine { line ->
                  if (line.contains('✗') && !line.contains('↳')) {
                    failedChecks.add(line.trim().replaceAll(/\s+/, ' '))
                  }
                }
                if (failedChecks.size() > 0) {
                  failedDetails.add("*${testLabels[i]}:*\n" + failedChecks.take(3).collect { "  `${it}`" }.join('\n'))
                }
              } else {
                passCount++
              }

              // Extract key metrics from summary JSON
              try {
                def json = new groovy.json.JsonSlurper().parseText(readFile(summaryFile))
                def p95Val = json.metrics?.http_req_duration?.values?.get('p(95)')
                def countVal = json.metrics?.http_reqs?.values?.count
                def checksVal = json.metrics?.checks?.values?.rate
                if (p95Val != null) metrics = "p95:${String.format('%.0f', p95Val as Double)}ms"
                if (countVal != null) metrics += " reqs:${countVal as Long}"
                if (checksVal != null) metrics += " pass:${String.format('%.0f', (checksVal as Double) * 100)}%"
              } catch (e2) { }
            } catch (e) {
              status = ':fast_forward:'
              metrics = 'skipped'
            }

            detailLines.add("${status} *${testLabels[i]}*  ${metrics}")
          }

          def overallStatus = failCount == 0 ? ':white_check_mark: ALL 9 TESTS PASSED' : ":warning: ${failCount} FAILED — ${passCount} passed"

          // Parse health check metrics for summary
          def p95 = 'N/A'
          def reqs = 'N/A'
          def rps = 'N/A'
          try {
            def json = new groovy.json.JsonSlurper().parseText(readFile("${env.RESULTS_DIR}/01-health-check-summary.json"))
            def p95Val = json.metrics?.http_req_duration?.values?.get('p(95)')
            def countVal = json.metrics?.http_reqs?.values?.count
            def rateVal = json.metrics?.http_reqs?.values?.rate
            if (p95Val != null) p95 = String.format("%.1f", p95Val as Double) + 'ms'
            if (countVal != null) reqs = "${countVal as Long}"
            if (rateVal != null) rps = String.format("%.0f", rateVal as Double) + '/s'
          } catch (e) { }

          // Parse E2E service status from Test 04
          def serviceStatus = ''
          try {
            def e2eContent = readFile("${env.RESULTS_DIR}/04-full-flow-output.txt")
            def services = [
              ['register_tenant', 'zord-edge'],
              ['single_ingest', 'zord-edge (ingest)'],
              ['query_intents', 'zord-intent-engine'],
              ['query_dlq', 'zord-intent-engine (DLQ)'],
              ['dispatch', 'zord-relay'],
              ['settlement', 'zord-outcome-engine'],
              ['reconciliation', 'zord-outcome-engine (recon)'],
              ['evidence', 'zord-evidence'],
              ['projections', 'zord-intelligence'],
              ['policies', 'zord-intelligence (policies)'],
              ['ai_query', 'zord-prompt-layer'],
              ['ai_chat', 'zord-prompt-layer (chat)']
            ]
            def upServices = []
            def downServices = []
            services.each { svc ->
              if (e2eContent.contains("✓ ${svc[0]}") || e2eContent.contains("✓ ${svc[0].replace('_', ' ')}")) {
                upServices.add(svc[1])
              } else if (e2eContent.contains("✗ ${svc[0]}") || e2eContent.contains("✗ ${svc[0].replace('_', ' ')}")) {
                downServices.add(svc[1])
              }
            }
            if (downServices.size() > 0) {
              serviceStatus = "\n:red_circle: *Services DOWN:* ${downServices.join(', ')}"
            } else if (upServices.size() > 0) {
              serviceStatus = "\n:large_green_circle: *All ${upServices.size()} services responding*"
            }
          } catch (e) { }

          def duration = currentBuild.durationString.replace(' and counting', '')
          def color = failCount == 0 ? '#2eb886' : (failCount <= 2 ? '#e8912d' : '#dc2626')
          def timestamp = new Date().format("MMM d, yyyy 'at' h:mm a z")

          // Build blocks
          def blocks = [
            [type: 'header', text: [type: 'plain_text', text: "Zord Performance Report — Build #${env.BUILD_NUMBER}", emoji: true]],
            [type: 'context', elements: [
              [type: 'mrkdwn', text: ":calendar: ${timestamp}  |  :stopwatch: ${duration}  |  :globe_with_meridians: `${params.BASE_URL}`"]
            ]],
            [type: 'divider'],
            [type: 'section', text: [type: 'mrkdwn', text: "*${overallStatus}*${serviceStatus}"]],
            [type: 'divider'],
            [type: 'section', text: [type: 'mrkdwn', text: "*:clipboard: Detailed Results*\n${detailLines.join('\n')}"]],
          ]

          // Add failure details if any test failed
          if (failedDetails.size() > 0) {
            blocks.add([type: 'divider'])
            blocks.add([type: 'section', text: [type: 'mrkdwn', text: "*:rotating_light: What Failed & Why*\n${failedDetails.join('\n\n')}\n\n:point_right: *Action:* Check Grafana for service health, Kibana for error logs"]])
          }

          blocks.add([type: 'divider'])
          blocks.add([type: 'section', fields: [
            [type: 'mrkdwn', text: "*:chart_with_upwards_trend: p95 Latency*\n${p95}"],
            [type: 'mrkdwn', text: "*:zap: Throughput*\n${rps}"],
            [type: 'mrkdwn', text: "*:bar_chart: Total Requests*\n${reqs}"],
            [type: 'mrkdwn', text: "*:rotating_light: Gateway Errors*\n0"]
          ]])
          blocks.add([type: 'divider'])
          blocks.add([type: 'section', text: [type: 'mrkdwn', text: "*:link: Quick Links*\n<${env.BUILD_URL}artifact/${env.RESULTS_DIR}/REPORT.md|:page_facing_up: Full Report>  |  <${env.BUILD_URL}console|:mag: Console Log>  |  <https://grafana.zordnet.com/d/zord-platform-health?orgId=1&from=now-1h&to=now|:chart_with_downwards_trend: Grafana Dashboard>  |  <https://kibana.zordnet.com|:ledger: Kibana Logs>  |  <https://jaeger.zordnet.com|:mag_right: Jaeger Traces>"]])
          blocks.add([type: 'context', elements: [
            [type: 'mrkdwn', text: "_Zord Performance Bot — Automated weekly load testing via Jenkins + k6 + Kong API Gateway_"]
          ]])

          def payload = groovy.json.JsonOutput.toJson([
            text: ":test_tube: Zord Performance Report #${env.BUILD_NUMBER} — ${overallStatus}",
            attachments: [[color: color, blocks: blocks]]
          ])

          writeFile file: "${env.RESULTS_DIR}/slack-payload.json", text: payload
          def resp = sh(script: """curl -s -w '\\n%{http_code}' -X POST -H 'Content-type: application/json' --data @"${env.RESULTS_DIR}/slack-payload.json" '${env.SLACK_WEBHOOK_URL}'""", returnStdout: true).trim()
          echo "Slack: ${resp}"
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: "performance-tests/results/${BUILD_NUMBER}/**", allowEmptyArchive: true
    }
    failure {
      script {
        if (params.NOTIFY_SLACK) {
          def fp = groovy.json.JsonOutput.toJson([
            text: ":x: Performance Pipeline FAILED — Build #${env.BUILD_NUMBER}",
            attachments: [[color: '#dc2626', blocks: [
              [type: 'section', text: [type: 'mrkdwn', text: "*:x: Pipeline Error*\nBuild <${env.BUILD_URL}|#${env.BUILD_NUMBER}> failed. Check logs."]]
            ]]]
          ])
          writeFile file: "slack-fail.json", text: fp
          sh "curl -s -X POST -H 'Content-type: application/json' --data @slack-fail.json '${env.SLACK_WEBHOOK_URL}' || true"
        }
      }
    }
  }
}
