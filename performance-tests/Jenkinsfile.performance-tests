pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 30, unit: 'MINUTES')
  }

  parameters {
    string(name: 'BASE_URL', defaultValue: 'https://api.zordnet.com', description: 'Base URL to test against')
    string(name: 'ADMIN_KEY', defaultValue: 'zord123', description: 'Admin API key for tenant registration')
    booleanParam(name: 'RUN_SPIKE_TEST', defaultValue: true, description: 'Run spike test (200 users — high load)')
    booleanParam(name: 'NOTIFY_SLACK', defaultValue: true, description: 'Send results to Slack')
    string(name: 'SLACK_CHANNEL', defaultValue: '#zord-performance-testing-bot', description: 'Slack channel for results')
  }

  environment {
    RESULTS_DIR = "performance-tests/results/${BUILD_NUMBER}"
    SCRIPTS_DIR = "performance-tests/scripts"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install k6') {
      steps {
        sh '''
          if ! command -v k6 &> /dev/null; then
            echo "Installing k6..."
            sudo yum install -y https://dl.k6.io/rpm/repo.rpm || true
            sudo yum install -y k6 || {
              curl -sL https://github.com/grafana/k6/releases/download/v0.49.0/k6-v0.49.0-linux-amd64.tar.gz | tar xz
              sudo mv k6-v0.49.0-linux-amd64/k6 /usr/local/bin/k6
            }
          fi
          k6 version

          # Install pandoc for PDF report generation
          if ! command -v pandoc &> /dev/null; then
            sudo yum install -y pandoc wkhtmltopdf 2>/dev/null || true
          fi
        '''
      }
    }

    stage('Pre-Test: Capture Cluster State') {
      steps {
        sh """
          mkdir -p "${RESULTS_DIR}"
          kubectl top nodes > "${RESULTS_DIR}/pre-test-nodes.txt" 2>/dev/null || echo "kubectl unavailable" > "${RESULTS_DIR}/pre-test-nodes.txt"
          kubectl top pods -n zord > "${RESULTS_DIR}/pre-test-pods.txt" 2>/dev/null || echo "kubectl unavailable" > "${RESULTS_DIR}/pre-test-pods.txt"
          kubectl get hpa -n zord > "${RESULTS_DIR}/pre-test-hpa.txt" 2>/dev/null || echo "kubectl unavailable" > "${RESULTS_DIR}/pre-test-hpa.txt"
        """
      }
    }

    stage('Test 1: Health Check (100 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/01-health-check-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/01-health-check.js" \
            2>&1 | tee "${RESULTS_DIR}/01-health-check-output.txt"
        """
      }
    }

    stage('Test 2: Tenant Registration (20 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/02-tenant-reg-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/02-tenant-registration.js" \
            2>&1 | tee "${RESULTS_DIR}/02-tenant-reg-output.txt"
        """
      }
    }

    stage('Test 3: Bulk Ingest (10 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/03-bulk-ingest-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/03-bulk-ingest.js" \
            2>&1 | tee "${RESULTS_DIR}/03-bulk-ingest-output.txt"
        """
      }
    }

    stage('Test 4: Full End-to-End Flow (20 users)') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/04-full-flow-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            --env ADMIN_KEY="${params.ADMIN_KEY}" \
            "${SCRIPTS_DIR}/04-full-flow.js" \
            2>&1 | tee "${RESULTS_DIR}/04-full-flow-output.txt"
        """
      }
    }

    stage('Test 5: Rate Limiting') {
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/05-rate-limit-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/05-rate-limit.js" \
            2>&1 | tee "${RESULTS_DIR}/05-rate-limit-output.txt"
        """
      }
    }

    stage('Test 6: Spike Test (200 users)') {
      when {
        expression { return params.RUN_SPIKE_TEST }
      }
      steps {
        sh """
          k6 run \
            --summary-export="${RESULTS_DIR}/06-spike-test-summary.json" \
            --env BASE_URL="${params.BASE_URL}" \
            "${SCRIPTS_DIR}/06-spike-test.js" \
            2>&1 | tee "${RESULTS_DIR}/06-spike-test-output.txt"
        """
      }
    }

    stage('Post-Test: Capture Cluster State') {
      steps {
        sh """
          kubectl top nodes > "${RESULTS_DIR}/post-test-nodes.txt" 2>/dev/null || true
          kubectl top pods -n zord > "${RESULTS_DIR}/post-test-pods.txt" 2>/dev/null || true
          kubectl get hpa -n zord > "${RESULTS_DIR}/post-test-hpa.txt" 2>/dev/null || true
          kubectl get pods -n zord > "${RESULTS_DIR}/post-test-pod-status.txt" 2>/dev/null || true
        """
      }
    }

    stage('Generate Report') {
      steps {
        sh """
          bash performance-tests/generate-report.sh "${RESULTS_DIR}"
          echo "============================================"
          echo "  PERFORMANCE TEST REPORT"
          echo "============================================"
          cat "${RESULTS_DIR}/REPORT.md"
        """
      }
    }

    stage('Notify Slack') {
      when {
        expression { return params.NOTIFY_SLACK }
      }
      steps {
        script {
          def report = readFile("${env.RESULTS_DIR}/REPORT.md")
          def summary = report.take(500) // First 500 chars

          slackSend(
            channel: params.SLACK_CHANNEL,
            color: currentBuild.result == 'SUCCESS' ? 'good' : 'danger',
            message: """🚀 *Performance Test Results — Build #${env.BUILD_NUMBER}*
📊 Target: ${params.BASE_URL}
⏱️ Duration: ${currentBuild.durationString}
📋 Full report in Jenkins artifacts

${summary}..."""
          )
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: "performance-tests/results/${BUILD_NUMBER}/**", allowEmptyArchive: true
    }
    failure {
      script {
        if (params.NOTIFY_SLACK) {
          slackSend(
            channel: params.SLACK_CHANNEL,
            color: 'danger',
            message: "❌ Performance tests FAILED — Build #${env.BUILD_NUMBER}\n${env.BUILD_URL}"
          )
        }
      }
    }
  }
}
